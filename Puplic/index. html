        '🔐 Password Reset - CryptoPro',
        'Hi ' + users[email].name + ',\n\n' +
        '🔐 Password Reset Request\n\n' +
        'Your temporary password is:\n\n' +
        '🔑 ' + tempPass + '\n\n' +
        'Please login using this password and change it in your account settings.\n\n' +
        'If you didn\'t request this, please contact support immediately.\n\n' +
        'Best regards,\nCryptoPro Team'
    );
    
