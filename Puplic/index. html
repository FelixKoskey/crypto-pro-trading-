            <div class="form-group"><label>Referral Code (Optional)</label><input type="text" id="signupRefCode" placeholder="Enter referral code"></div>
            <button type="submit" class="btn btn-primary" style="width: 100%;">Create Account</button>
        </form>
        <div class="link-text">Already have an account? <a onclick="showLayer('loginLayer')">Login here</a></div>
    </div>
</div>

<!-- LOGIN LAYER -->
<div id="loginLayer" class="layer">
    <nav class="navbar">
        <div class="logo" onclick="showLayer('homeLayer')"><span>💎</span><span>CryptoPro</span></div>
        <div class="nav-links"><button class="nav-btn btn-signup" onclick="showLayer('signupLayer')">Sign Up</button></div>
